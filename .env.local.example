# Copy this file to .env.local for local testing.
# In Vercel, add these same values under Project Settings -> Environment Variables.

# ── Anthropic ──────────────────────────────────────────────────────────────
# Get from console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ── Google Drive (legacy GSI flow — keep for Drive/Sheets access) ──────────
# Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID (Web application)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com

# ── Firebase Auth ──────────────────────────────────────────────────────────
# Get all four from Firebase Console -> Project Settings -> Your apps -> Web app -> SDK config
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
