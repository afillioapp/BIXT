# Copy this file to .env.local for local testing.
# In Vercel, add these same two values under Project Settings -> Environment Variables.

# Get this from console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Get this from Google Cloud Console -> APIs & Services -> Credentials (OAuth client ID, Web application)
# Must be exposed to the browser, hence the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
